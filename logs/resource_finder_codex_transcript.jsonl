{"type":"item.started","item":{"id":"item_26","type":"command_execution","command":"/bin/bash -lc \"pwd\nsource .venv/bin/activate\npython - << 'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json\n\nroot=Path('datasets')\nroot.mkdir(exist_ok=True)\n\nsummary=[]\nfor name in ['cifar10','svhn']:\n    print('loading',name)\n    ds=load_dataset(name)\n    out=root/name\n    ds.save_to_disk(str(out))\n    rec={\n      'name':name,\n      'splits':{k:len(v) for k,v in ds.items()},\n      'features':str(ds[list(ds.keys())[0]].features)\n    }\n    sample=ds[list(ds.keys())[0]][:5]\n    sdir=out/'samples'\n    sdir.mkdir(parents=True,exist_ok=True)\n    # reduce image payload; keep labels for doc\n    slim=[]\n    for i in range(5):\n      item={}\n      for k,v in sample.items():\n        if k=='image':\n          item[k]=f'<PIL image {sample[k][i].size}>'\n        else:\n          item[k]=v[i]\n      slim.append(item)\n    (sdir/'samples.json').write_text(json.dumps(slim,indent=2))\n    summary.append(rec)\n\nPath('datasets/dataset_summary.json').write_text(json.dumps(summary,indent=2))\nprint('done')\nfor r in summary:\n    print(r)\nPY\nfind datasets -maxdepth 2 -type d | sort\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
