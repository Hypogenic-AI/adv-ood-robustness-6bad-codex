{"type":"item.started","item":{"id":"item_28","type":"command_execution","command":"/bin/bash -lc \"pwd\nsource .venv/bin/activate\nuv add pillow\npython - << 'PY'\nfrom datasets import load_dataset, load_from_disk\nfrom pathlib import Path\nimport json\n\nroot=Path('datasets')\nsummary=[]\n\n# ensure cifar10 summary/samples\ncifar=load_from_disk(str(root/'cifar10'))\nfor name,ds in [('cifar10',cifar)]:\n    rec={'name':name,'splits':{k:len(v) for k,v in ds.items()},'features':str(ds[list(ds.keys())[0]].features)}\n    split=list(ds.keys())[0]\n    sample=ds[split][:5]\n    sdir=root/name/'samples'; sdir.mkdir(parents=True,exist_ok=True)\n    slim=[]\n    for i in range(5):\n        item={k:(f\\\"<PIL image {sample[k][i].size}>\\\" if k=='img' or k=='image' else sample[k][i]) for k in sample.keys()}\n        slim.append(item)\n    (sdir/'samples.json').write_text(json.dumps(slim,indent=2))\n    summary.append(rec)\n\n# download svhn\nsvhn=load_dataset('svhn','cropped_digits')\nsvhn.save_to_disk(str(root/'svhn'))\nrec={'name':'svhn','splits':{k:len(v) for k,v in svhn.items()},'features':str(svhn[list(svhn.keys())[0]].features)}\nsample=svhn['train'][:5]\nsdir=root/'svhn'/'samples'; sdir.mkdir(parents=True,exist_ok=True)\nslim=[]\nfor i in range(5):\n    item={k:(f\\\"<PIL image {sample[k][i].size}>\\\" if k=='image' else sample[k][i]) for k in sample.keys()}\n    slim.append(item)\n(sdir/'samples.json').write_text(json.dumps(slim,indent=2))\nsummary.append(rec)\n\nPath('datasets/dataset_summary.json').write_text(json.dumps(summary,indent=2))\nprint(summary)\nPY\nfind datasets -maxdepth 2 -type d | sort\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
