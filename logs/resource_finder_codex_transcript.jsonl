{"type":"item.started","item":{"id":"item_15","type":"command_execution","command":"/bin/bash -lc \"pwd\nsource .venv/bin/activate\npython - << 'PY'\nimport json, re, requests, os\nfrom pathlib import Path\nfrom urllib.parse import urlparse\n\nroot=Path('papers')\nroot.mkdir(exist_ok=True)\nresults=json.loads(Path('papers/paper_finder_results.json').read_text())['papers']\n\nrows=[]\nfor i,p in enumerate(results,1):\n    url=p.get('url','')\n    sid=url.rstrip('/').split('/')[-1] if 'semanticscholar.org/paper/' in url else None\n    title=p.get('title','untitled')\n    safe_title=re.sub(r'[\"'^a-zA-Z0-9]+'\"','_',title).strip('_')[:70]\n    year=p.get('year','na')\n    out_name=f\\\"{i:02d}_{year}_{safe_title}.pdf\\\"\n    out_path=root/out_name\n    status='no_id'\n    pdf_url=None\n    if sid:\n        api=f\\\"https://api.semanticscholar.org/graph/v1/paper/{sid}?fields=title,year,openAccessPdf,url,externalIds,venue,authors\\\"\n        try:\n            r=requests.get(api,timeout=30)\n            if r.status_code==200:\n                data=r.json()\n                if data.get('openAccessPdf') and data['openAccessPdf'].get('url'):\n                    pdf_url=data['openAccessPdf']['url']\n                elif data.get('externalIds',{}).get('ArXiv'):\n                    ax=data['externalIds']['ArXiv']\n                    pdf_url=f\\\"https://arxiv.org/pdf/{ax}.pdf\\\"\n                if pdf_url:\n                    rr=requests.get(pdf_url,timeout=60)\n                    ctype=rr.headers.get('content-type','')\n                    if rr.status_code==200 and (b'%PDF' in rr.content[:2048] or 'pdf' in ctype.lower()):\n                        out_path.write_bytes(rr.content)\n                        status='downloaded'\n                    else:\n                        status=f\\\"pdf_fetch_failed_{rr.status_code}\\\"\n                else:\n                    status='no_open_pdf'\n            else:\n                status=f\\\"api_{r.status_code}\\\"\n        except Exception as e:\n            status=f\\\"error_{type(e).__name__}\\\"\n    rows.append({\n        'idx':i,'title':title,'year':year,'authors':p.get('authors',''),'citations':p.get('citations',0),\n        'relevance':p.get('relevance',0),'semanticscholar_url':url,'paper_id':sid or '',\n        'pdf_url':pdf_url or '','file':str(out_path) if out_path.exists() else '', 'status':status\n    })\n\nPath('papers/papers_metadata.json').write_text(json.dumps(rows,indent=2))\nprint('total',len(rows))\nprint('downloaded',sum(1 for r in rows if r['status']=='downloaded'))\nfor r in rows:\n    if r['status']\"'!='\"'downloaded':\n        print(f\\\"MISS {r['idx']:02d}: {r['status']} :: {r['title'][:80]}\\\")\nPY\nls -1 papers/*.pdf | wc -l\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
